# Backend Environment Variables (for Render)
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/cusb_db

# JWT Configuration
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-32-character-string-here
JWT_EXPIRE=7d

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS Configuration
# Set this to your Netlify frontend domain to restrict API access
# Example: https://cusb-university.netlify.app
CORS_ORIGIN=*

# Frontend Environment Variables (for Netlify)
# These are injected during build via build-config.js
# Set these in Netlify's environment variables settings
API_BASE_URL=https://your-render-backend.onrender.com/api
UPLOAD_BASE_URL=https://your-render-backend.onrender.com
